[
  {
    "id": "phrase-health-178",
    "type": "phrase",
    "order": 139,
    "category": "Health",
    "front": "ഏറ്റവും അടുത്തുള്ള ആശുപത്രി/ഡോക്ടർ എവിടെയാണ്?",
    "back": "Where is the nearest hospital/doctor?",
    "transliteration": "ettavum aduthulla aashupathri/doctar evideyaanu?",
    "meaning": "Where is the nearest hospital/doctor?",
    "audioText": "ഏറ്റവും അടുത്തുള്ള ആശുപത്രി/ഡോക്ടർ എവിടെയാണ്?"
  },
  {
    "id": "phrase-health-179",
    "type": "phrase",
    "order": 140,
    "category": "Health",
    "front": "എനിക്ക് ഇംഗ്ലീഷ്/ഹിന്ദി/മലയാളം സംസാരിക്കുന്ന ഒരു ഡോക്ടറെ വേണം.",
    "back": "I need a doctor who speaks English/Hindi/Malayalam.",
